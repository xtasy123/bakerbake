# Copy this file to .env and fill in your Supabase project values.
# Keep the service role key private. Do not put it in index.html or any frontend file.

HOST=127.0.0.1
PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-project-anon-key
SUPABASE_JWT_SECRET=your-project-jwt-secret
PRODUCT_IMAGE_BUCKET=product-images
POS_USERS_JSON=[{"username":"cashier","name":"Cashier","role":"cashier","passwordHash":"paste-cashier-password-hash-here"},{"username":"admin","name":"Admin","role":"admin","passwordHash":"paste-admin-password-hash-here"}]

# Optional: Google Sheets inventory backup sync.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
INVENTORY_SYNC_SECRET=replace-with-a-long-random-sync-secret
